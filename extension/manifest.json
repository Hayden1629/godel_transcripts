{
  "manifest_version": 3,
  "name": "Transcript Downloader",
  "version": "1.1",
  "description": "Download earnings transcripts from the Transcript Hub",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Transcript Downloader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["<all_urls>"]
}
